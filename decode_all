input_xls = pd.ExcelFile(excel_data_path)
answer_xls = pd.ExcelFile(answer_key_path)
cattle_xls = pd.ExcelFile(cattle_answer_key_path)

with pd.ExcelWriter(output_path, engine="openpyxl") as writer:

