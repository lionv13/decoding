with pd.ExcelWriter(output_path, engine="openpyxl") as writer:
    for input_sheet in input_xls.sheet_names:
        print("\n============================================================")
        print(f"Processing sheet: {input_sheet}")
        print("============================================================")

        df = pd.read_excel(input_xls, sheet_name=input_sheet)
        df.rename(columns={col: str(col).strip() for col in df.columns}, inplace=True)

        if df.empty:
            df.to_excel(writer, sheet_name=input_sheet[:31], index=False)
            print("Empty sheet copied.")
            continue

        try:
            detected_species = detect_species_from_sheet(df, input_sheet)
            print(f"Detected species: {detected_species}")

            answer_sheet = find_matching_answer_sheet(answer_xls, detected_species, input_sheet)

            print("Using answer-key workbook: updated Biocheck Answer - key 2025.xlsx")
            print(f"Using answer-key sheet: {answer_sheet}")

            # IMPORTANT: header=None preserves the answer-key columns.
            keys_dict = pd.read_excel(answer_xls, sheet_name=answer_sheet, header=None)

            survey_dictionary = build_survey_dictionary(keys_dict)
            decoded_df = decode_dataframe(df, survey_dictionary)

            decoded_df.to_excel(writer, sheet_name=input_sheet[:31], index=False)
            print("Sheet decoded successfully.")

        except Exception as e:
            print(f"WARNING: Could not decode sheet '{input_sheet}'. Copied original sheet.")
            print(f"Reason: {e}")
            df.to_excel(writer, sheet_name=input_sheet[:31], index=False)

print(f"\nDecoded workbook saved to: {output_path}")
