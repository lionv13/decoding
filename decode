import re
import os

# =============================================================
# File paths and survey
# =============================================================

answer_key_path = "/Users/gast/Documents/biocheck/trabajos/2026/mayo/decode/updated Biocheck Answer - key 2025.xlsx"
data_path = "/Users/gast/Documents/biocheck/trabajos/2025/mayo/rawdata/submissions-pigs_indoor_old.xlsx"

# Paste your desired output folder here
output_folder = "/Users/gast/Documents/biocheck/trabajos/2026/test"

# Species / survey name
survey_key = "Pigs_indoor_old"

# =============================================================
# Output path
# =============================================================

os.makedirs(output_folder, exist_ok=True)

safe_species = survey_key.replace(" ", "_")
input_filename = os.path.splitext(os.path.basename(data_path))[0]

output_path = os.path.join(
    output_folder,
    f"{input_filename}_{safe_species}_decoded.xlsx"
