            df.to_excel(writer, sheet_name=input_sheet[:31], index=False)
            print("Empty sheet copied.")
            continue

        try:
            detected_species = detect_species_from_sheet(df, input_sheet)
            answer_sheet = find_matching_answer_sheet(
                answer_xls,
                detected_species,
                input_sheet
            )

            print(f"Detected species: {detected_species}")

            # =====================================================
            # Dairy and Beef use the alternate cattle answer key
            # =====================================================

            if detected_species == "dairy cattle":
                print("Using answer-key workbook: Biocheck answer-key (1).xlsx")
                print("Using answer-key sheet: Biocheck.Dairy cattle")

                keys_dict = pd.read_excel(
                    cattle_xls,
                    sheet_name="Biocheck.Dairy cattle"
                )

            elif detected_species == "beef cattle":
                print("Using answer-key workbook: Biocheck answer-key (1).xlsx")
                print("Using answer-key sheet: Biocheck.Beef cattle")

                keys_dict = pd.read_excel(
                    cattle_xls,
                    sheet_name="Biocheck.Beef cattle"
                )

            else:
                print("Using answer-key workbook: updated Biocheck Answer - key 2025.xlsx")
                print(f"Using answer-key sheet: {answer_sheet}")

                keys_dict = pd.read_excel(
                    answer_xls,
                    sheet_name=answer_sheet
                )

            survey_dictionary = build_survey_dictionary(keys_dict)

            encoded_df = encode_dataframe(df, survey_dictionary)

            encoded_df.to_excel(
                writer,
                sheet_name=input_sheet[:31],
                index=False
            )

            print("Sheet encoded successfully.")

        except Exception as e:
            print(f"⚠️ Could not encode sheet '{input_sheet}'. Copied original sheet.")
            print(f"Reason: {e}")

            df.to_excel(
                writer,
                sheet_name=input_sheet[:31],
                index=False
            )

print(f"\n✅ Encoded workbook saved to: {output_path}")
